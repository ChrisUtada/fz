# Godot 4 生成目录（不要提交）
.godot/
.import/

# 导出与构建产物
export/
/android/export/
/build/
bin/
# GDExtension vendored：只入库预编译 dll（运行时必需），源码/构建产物全部忽略
addons/godot_global_input/godot-cpp/
addons/godot_global_input/src/*.cpp
addons/godot_global_input/src/*.h
addons/godot_global_input/src/SConstruct
addons/godot_global_input/src/.sconsign.dblite
addons/godot_global_input/src/register_types.*
addons/godot_global_input/src/trackers/
# 仅白名单 src/bin/windows/*.dll（含 MinGW 运行时 libgcc/libstdc++/libwinpthread）
!addons/godot_global_input/src/bin/
addons/godot_global_input/src/bin/**
!addons/godot_global_input/src/bin/windows/
!addons/godot_global_input/src/bin/windows/*.dll
# 导出的游戏包（重新导出即得，不入库）
*.pck

# Mono / C# 相关（若后续用 C#）
.mono/
data_*/
mono_crash.*.json

# 自动导入的翻译文件（由 CSV 生成）
*.translation

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp

# 本地工具数据（WorkBuddy 内部，非项目内容）
.workbuddy/

# Python 缓存与临时测试产物（companion 输入统计脚本）
__pycache__/
*.pyc
_rawtest.json

# GDExtension 编辑器临时 dll（顶层散落副本与带 ~ 前缀的临时文件，不入库）
/GlobalInput.windows.template_debug.x86_64.dll
**/~*
