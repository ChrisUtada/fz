# Godot 4 生成目录（不要提交）
.godot/
.import/

# 导出与构建产物
export/
/android/export/
/build/
bin/
# GDExtension 预编译运行时（虽在 bin/ 下，但属必需依赖，需入库；否则克隆后扩展加载失败）
!addons/godot_global_input/src/bin/
# 导出的游戏包（重新导出即得，不入库）
*.pck

# Mono / C# 相关（若后续用 C#）
.mono/
data_*/
mono_crash.*.json

# 自动导入的翻译文件（由 CSV 生成）
*.translation

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp

# 本地工具数据（WorkBuddy 内部，非项目内容）
.workbuddy/

# Python 缓存与临时测试产物（companion 输入统计脚本）
__pycache__/
*.pyc
_rawtest.json

# GDExtension 构建/编辑器临时 dll（散落副本与带 ~ 前缀的临时文件，不入库）
/GlobalInput.windows.template_debug.x86_64.dll
**/~GlobalInput.windows.template_debug.x86_64.dll
