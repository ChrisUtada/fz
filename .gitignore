# Godot 4 生成目录（不要提交）
.godot/
.import/

# 导出与构建产物
export/
/android/export/
/build/
bin/
# 导出的游戏包（重新导出即得，不入库）
*.pck

# Mono / C# 相关（若后续用 C#）
.mono/
data_*/
mono_crash.*.json

# 自动导入的翻译文件（由 CSV 生成）
*.translation

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 编辑器 / IDE
.vscode/
.idea/
*.swp

# 本地工具数据（WorkBuddy 内部，非项目内容）
.workbuddy/

# Python 缓存与临时测试产物（companion 输入统计脚本）
__pycache__/
*.pyc
_rawtest.json
